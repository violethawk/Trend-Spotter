# Required — used for LLM clustering
OPENAI_API_KEY=your_openai_api_key_here

# Optional — enables web search source (SerpAPI)
SERPAPI_KEY=your_serpapi_key_here

# Optional — increases GitHub API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=your_github_token_here

# Optional — protects the REST API (omit for open access)
# TREND_SPOTTER_API_KEY=your_api_key_here
